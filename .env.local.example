NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=

# ── Hostess (/host) shift-mode access ──
# Hostesses sign in at /host/login with their phone + password.
# Passwords are set by the manager in /admin/employees (per employee).
# Only employees with role 'host' or 'manager' can sign in.
# Secret used to sign the hostess session cookie — a long random string.
# If unset, the login route falls back to NEXTAUTH_SECRET. Rotating this
# invalidates all existing host sessions.
HOST_COOKIE_SECRET=

# ── Venue capacity ──
# Zone capacities (bar stools, table seats) and the per-reservation bar
# party cap live in the `zones` DB table — edit them via SQL in Supabase,
# not here. See supabase-migration-zones.sql + lib/zones.ts.
#
# The BAR_CAPACITY / TABLE_CAPACITY / MAX_BAR_PARTY env vars are now a
# last-resort fallback used only if the DB is unreachable on boot. They
# default to 14 / 44 / 4 (the real physical venue numbers) — set them
# here only if you want the emergency fallback to be something different.
# BAR_CAPACITY=14
# TABLE_CAPACITY=44
# MAX_BAR_PARTY=4
#
# How long a single reservation holds its seats, in minutes. Default 120.
# RESERVATION_DURATION_MINUTES=120

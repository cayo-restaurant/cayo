NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=

# Admin panel password (use a strong one in production!)
ADMIN_PASSWORD=cayo2026

# ── Hostess (/host) shift-mode access ──
# 4-digit PIN the on-shift hostess types into the tablet at /host.
# Change this to rotate access (all existing sessions stay valid until they
# expire, but no one can log in again without the new PIN).
HOST_PIN=1234
# Secret used to sign the hostess session cookie. Any non-empty value works —
# use a long random string. If unset, the login route falls back to
# NEXTAUTH_SECRET.
HOST_COOKIE_SECRET=

# ── Venue capacity ──
# How many seats the venue has in each area. A reservation request is rejected
# if adding it would push the total over the limit at that time (see
# lib/capacity.ts). Leave commented out / unset to keep the system effectively
# uncapped (defaults to 999 each).
# BAR_CAPACITY=20
# TABLE_CAPACITY=40
# How long a single reservation holds its seats, in minutes. Default 120.
# RESERVATION_DURATION_MINUTES=120
